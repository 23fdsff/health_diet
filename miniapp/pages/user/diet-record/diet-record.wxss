.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 8rpx;
}

.input,
.picker-value {
  background: #f7f9fb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
}

.btn-primary {
  margin-top: 32rpx;
}

.record-item {
  padding: 16rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #555;
}

.row.desc {
  margin-top: 4rpx;
  color: #777;
}

.cal {
  color: #3FB489;
}

.stat {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #666;
}

